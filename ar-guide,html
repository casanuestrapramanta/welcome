<!DOCTYPE html>
<html lang="el">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Casa Nuestra - AR Mountain Guide</title>
    
    <script src="https://aframe.io/releases/1.4.0/aframe.min.js"></script>
    <script src="https://raw.githack.com/AR-js-org/AR.js/master/aframe/build/aframe-ar-nft.js"></script>
</head>

<body style="margin: 0; overflow: hidden;">

    <a-scene 
        vr-mode-ui="enabled: false"
        embedded
        arjs="sourceType: webcam; debugUIEnabled: false; videoTexture: true;">
        
        <a-text
            value="⛰️ Strogoula (2.112m)"
            scale="20 20 20"
            look-at="[gps-camera]"
            align="center"
            color="#FFD700"
            gps-entity-place="latitude: 39.5186; longitude: 21.1183;"
            position="0 50 0">
        </a-text>

        <a-text
            value="🥾 Pramanta Refuge (1.300m)"
            scale="15 15 15"
            look-at="[gps-camera]"
            align="center"
            color="#00FFCC"
            gps-entity-place="latitude: 39.5112; longitude: 21.1215;"
            position="0 30 0">
        </a-text>

        <a-camera gps-camera rotation-reader></a-camera>

    </a-scene>

</body>
</html>